# ===================================================================
# CONFIGURACIÓN DE VARIABLES DE ENTORNO - KYDIRA API (TEMPLATE)
# ===================================================================
# Copia este archivo como '.env' (o agrégalo a tu configuración de ejecución en tu IDE)
# y reemplaza los valores con tus credenciales de Supabase.
# ¡NUNCA subas el archivo '.env' real a GitHub!

# URL/Host de tu base de datos Supabase (se encuentra en Settings -> Database -> Connection Info)
# Ejemplo: db.abcdefghijklmnopqrst.supabase.co
DB_HOST=your-supabase-db-host

# Puerto de la base de datos (por defecto es 5432)
DB_PORT=5432

# Nombre de la base de datos (por defecto en Supabase es postgres)
DB_NAME=postgres

# Usuario de la base de datos (por defecto es postgres)
DB_USER=postgres

# Contraseña que definiste al crear el proyecto en Supabase
DB_PASSWORD=your-supabase-db-password
